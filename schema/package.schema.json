{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "termux-store package metadata",
  "type": "object",
  "required": [
    "name",
    "termux_package",
    "gui",
    "x11_required",
    "category",
    "short_description",
    "long_description",
    "install_command",
    "submitted_by",
    "last_updated"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9+_.-]*$"
    },
    "termux_package": {
      "type": "boolean",
      "const": true
    },
    "gui": {
      "type": "boolean"
    },
    "x11_required": {
      "type": "boolean"
    },
    "category": {
      "type": "string",
      "enum": [
        "development",
        "terminal",
        "multimedia",
        "network",
        "utilities",
        "security",
        "graphics",
        "productivity",
        "games",
        "fonts"
      ]
    },
    "short_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "long_description": {
      "type": "string",
      "minLength": 1
    },
    "install_command": {
      "type": "string",
      "minLength": 1
    },
    "launch_command": {
      "type": "string"
    },
    "tips": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "community_rating": {
      "type": "object",
      "properties": {
        "works_great": {
          "type": "integer",
          "minimum": 0
        },
        "unstable": {
          "type": "integer",
          "minimum": 0
        },
        "broken": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "submitted_by": {
      "type": "string",
      "minLength": 1
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
